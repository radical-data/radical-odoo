<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Default configuration values are set via config_parameter defaults on fields -->

        <!-- Email alias: route emails to vendor-invoices@domain → account.move (vendor bill) -->
        <record id="mail_alias_vendor_bills" model="mail.alias">
            <field name="alias_name">vendor-invoices</field>
            <field name="alias_model_id" ref="account.model_account_move"/>
            <field name="alias_defaults">{"move_type": "in_invoice"}</field>
            <field name="alias_contact">everyone</field>
        </record>
        <!-- Background extraction cron (runs every 30s when async mode is enabled) -->
        <record id="ir_cron_ai_extraction_queue" model="ir.cron">
            <field name="name">AI Invoice Extraction Queue</field>
            <field name="model_id" ref="account.model_account_move"/>
            <field name="state">code</field>
            <field name="code">model._ai_cron_process_queue()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">minutes</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
