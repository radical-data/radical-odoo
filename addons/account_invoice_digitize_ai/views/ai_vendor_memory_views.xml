<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="ai_vendor_memory_view_tree" model="ir.ui.view">
        <field name="name">ai.vendor.memory.tree</field>
        <field name="model">ai.vendor.memory</field>
        <field name="arch" type="xml">
            <list>
                <header>
                    <button name="%(account_invoice_digitize_ai.ai_memory_export_action)d"
                            type="action" string="Export"/>
                    <button name="%(account_invoice_digitize_ai.ai_memory_import_action)d"
                            type="action" string="Import"/>
                </header>
                <field name="partner_id"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="field_name"/>
                <field name="ai_value"/>
                <field name="user_value"/>
                <field name="correction_count"/>
                <field name="auto_apply"/>
                <field name="last_correction_date"/>
            </list>
        </field>
    </record>

    <record id="ai_vendor_memory_view_form" model="ir.ui.view">
        <field name="name">ai.vendor.memory.form</field>
        <field name="model">ai.vendor.memory</field>
        <field name="arch" type="xml">
            <form string="Vendor Memory">
                <sheet>
                    <group>
                        <group>
                            <field name="partner_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="field_name"/>
                            <field name="correction_count"/>
                        </group>
                        <group>
                            <field name="ai_value"/>
                            <field name="user_value"/>
                            <field name="auto_apply"/>
                            <field name="last_correction_date"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="ai_vendor_memory_view_search" model="ir.ui.view">
        <field name="name">ai.vendor.memory.search</field>
        <field name="model">ai.vendor.memory</field>
        <field name="arch" type="xml">
            <search>
                <field name="partner_id"/>
                <field name="field_name"/>
                <filter name="auto_apply" string="Auto-apply" domain="[('auto_apply', '=', True)]"/>
                <group>
                    <filter name="group_partner" string="Vendor" context="{'group_by': 'partner_id'}"/>
                    <filter name="group_field" string="Field" context="{'group_by': 'field_name'}"/>
                    <filter name="group_company" string="Company" context="{'group_by': 'company_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="ai_vendor_memory_action" model="ir.actions.act_window">
        <field name="name">Vendor Memory</field>
        <field name="res_model">ai.vendor.memory</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="ai_vendor_memory_menu"
              name="Vendor Memory"
              parent="ai_digitize_root_menu"
              action="ai_vendor_memory_action"
              sequence="50"
              groups="account_invoice_digitize_ai.group_ai_digitize_manager"/>

</odoo>
