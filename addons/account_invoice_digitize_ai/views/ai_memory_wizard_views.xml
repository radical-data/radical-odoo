<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================================================
         Export Wizard
         ================================================================ -->

    <record id="ai_memory_export_wizard_view_form" model="ir.ui.view">
        <field name="name">ai.memory.export.wizard.form</field>
        <field name="model">ai.memory.export.wizard</field>
        <field name="arch" type="xml">
            <form string="Export Vendor Memory">
                <group>
                    <field name="export_all"/>
                    <field name="partner_ids" widget="many2many_tags"
                           invisible="export_all"/>
                </group>
                <group invisible="not export_data">
                    <field name="export_data" filename="export_filename"/>
                    <field name="export_filename" invisible="1"/>
                </group>
                <footer>
                    <button name="action_export" string="Export"
                            type="object" class="btn-primary"
                            invisible="export_data"/>
                    <button string="Close" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="ai_memory_export_action" model="ir.actions.act_window">
        <field name="name">Export Vendor Memory</field>
        <field name="res_model">ai.memory.export.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- ================================================================
         Import Wizard
         ================================================================ -->

    <record id="ai_memory_import_wizard_view_form" model="ir.ui.view">
        <field name="name">ai.memory.import.wizard.form</field>
        <field name="model">ai.memory.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Import Vendor Memory">
                <group>
                    <field name="import_file" filename="import_filename"
                           invisible="result_message"/>
                    <field name="import_filename" invisible="1"/>
                </group>
                <group invisible="not result_message">
                    <field name="result_message" nolabel="1"/>
                </group>
                <footer>
                    <button name="action_import" string="Import"
                            type="object" class="btn-primary"
                            invisible="result_message"/>
                    <button string="Close" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="ai_memory_import_action" model="ir.actions.act_window">
        <field name="name">Import Vendor Memory</field>
        <field name="res_model">ai.memory.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>


</odoo>
