# Build tooling used to install this deployment project package.
hatchling
hatch-odoo

# Runtime Python dependencies used by account_invoice_digitize_ai.
pdfplumber
factur-x
pyzbar

# OCA addons installed as Python packages.
odoo-addon-account-financial-report
odoo-addon-date-range

