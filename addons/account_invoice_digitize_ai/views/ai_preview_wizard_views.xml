<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- AI Extraction Preview wizard form -->
    <record id="ai_preview_wizard_form" model="ir.ui.view">
        <field name="name">ai.preview.wizard.form</field>
        <field name="model">ai.preview.wizard</field>
        <field name="arch" type="xml">
            <form string="AI Extraction Preview">
                <sheet>
                    <div class="oe_title">
                        <h2>Extraction Preview</h2>
                        <p class="text-muted">Review the extracted data before applying it to the invoice.</p>
                    </div>

                    <!-- Warnings -->
                    <field name="warnings" invisible="1"/>
                    <div class="alert alert-warning" role="alert"
                         invisible="not warnings">
                        <field name="warnings" nolabel="1"/>
                    </div>

                    <group>
                        <group string="Vendor">
                            <field name="vendor_name" string="Name"/>
                        </group>
                        <group string="Invoice">
                            <field name="invoice_ref" string="Reference"/>
                            <field name="purchase_order_ref" string="Purchase Order"
                                   invisible="not purchase_order_ref"/>
                            <field name="invoice_date" string="Date"/>
                        </group>
                    </group>

                    <!-- Vendor resolution (when no match found) -->
                    <field name="vendor_match_found" invisible="1"/>
                    <div class="alert alert-info" role="alert"
                         invisible="vendor_match_found">
                        <strong>Vendor not found:</strong>
                        The extracted vendor was not matched to any existing partner.
                        Please select an existing vendor or create a new one.
                    </div>
                    <group invisible="vendor_match_found" string="Vendor Resolution">
                        <group>
                            <field name="selected_partner_id"
                                   string="Select Existing Vendor"
                                   invisible="create_new_vendor"/>
                        </group>
                        <group>
                            <field name="create_new_vendor" widget="boolean_toggle"/>
                            <field name="new_vendor_name"
                                   invisible="not create_new_vendor"
                                   required="create_new_vendor"/>
                            <field name="new_vendor_vat"
                                   invisible="not create_new_vendor"/>
                        </group>
                    </group>
                    <group>
                        <group string="Amounts">
                            <field name="total_amount" string="Total"/>
                            <field name="currency" string="Currency"/>
                            <field name="tax_summary" string="Taxes"/>
                        </group>
                        <group string="Summary">
                            <field name="line_count" string="Line items"/>
                        </group>
                    </group>

                    <!-- Extracted line items (read-only table) -->
                    <field name="line_count" invisible="1"/>
                    <group string="Extracted Lines" col="1"
                           invisible="not line_count">
                        <field name="preview_line_ids" nolabel="1">
                            <list create="false" delete="false"
                                  default_order="sequence" edit="0">
                                <field name="sequence" column_invisible="1"/>
                                <field name="description" string="Description"/>
                                <field name="product_code" string="Code"
                                       optional="hide"/>
                                <field name="quantity" string="Qty"/>
                                <field name="unit_price" string="Unit Price"/>
                                <field name="tax_rate" string="Tax %"/>
                                <field name="subtotal" string="Subtotal"/>
                            </list>
                        </field>
                    </group>

                    <field name="preview_data" invisible="1"/>
                    <field name="move_id" invisible="1"/>
                </sheet>
                <footer>
                    <button name="action_apply" string="Apply to Invoice" type="object"
                            class="btn-primary"/>
                    <button name="action_discard" string="Discard" type="object"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
